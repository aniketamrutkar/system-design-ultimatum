      },
      "seed": 742909859,
      "text": "RECOMMENDATIONS:\n• Uber/Lyft: Geohash (p11) in Redis for fast lookup, combined with Quad Tree for complex logic\n• Netflix/Location-based: PostGIS with R-tree indexing for sub-meter accuracy\n• Google Maps: Combination of all 4 - S2 geometry (Quad Tree variant) + PostGIS + Elasticsearch\n• Mobile Apps: Geohash with local Redis cache for minimal bandwidth\n• Large-scale Search: Elasticsearch with geo_point and text search combined",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "index": "aA",
      "boundElements": [],
      "updated": 1767583158863,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "RECOMMENDATIONS:\n• Uber/Lyft: Geohash (p11) in Redis for fast lookup, combined with Quad Tree for complex logic\n• Netflix/Location-based: PostGIS with R-tree indexing for sub-meter accuracy\n• Google Maps: Combination of all 4 - S2 geometry (Quad Tree variant) + PostGIS + Elasticsearch\n• Mobile Apps: Geohash with local Redis cache for minimal bandwidth\n• Large-scale Search: Elasticsearch with geo_point and text search combined",
      "autoResize": true,
      "lineHeight": 1.8181818181818181
    },
