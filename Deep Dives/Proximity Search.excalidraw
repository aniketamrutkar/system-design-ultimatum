    {
      "id": "EgCtxmnc2K_A3WeiSEzYk",
      "type": "text",
      "x": 546.1246344281142,
      "y": 328.40914835190335,
      "width": 54.30877685546875,
      "height": 75.88482879166035,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aNV",
      "roundness": null,
      "seed": 670919587,
      "version": 409,
      "versionNonce": 1623496301,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766904755400,
      "link": null,
      "locked": false,
      "text": "Precision\nlevels:\nP1: ~5000km\nP5: ~4.8km\nP9: ~3.8m\nP11: ~1.5m\n(Uber)",
      "fontSize": 8.67255186190404,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "0ApCMRIiM8UkhC3mFt_FM",
      "originalText": "Precision levels:\nP1: ~5000km\nP5: ~4.8km\nP9: ~3.8m\nP11: ~1.5m (Uber)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 448,
      "versionNonce": 1855370765,
      "isDeleted": false,
      "id": "jR3_raqC4X28QgtQjl3io",
      "x": 500.1563276600415,
      "y": 421.6201532159554,
      "width": 240.87462426236152,
      "height": 230.30332181880647,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 980419299,
      "text": "How it works\n- Converts latitude/longitude into a string\n- Nearby locations share common prefixes\n- Precision controls search radius\n\nWhy it’s powerful\n- No tree traversal\n- Neighbor search = small string variations\n- Easy indexing in databases\n- Prebuilt libraries available\n- Scales extremely well\n\nExample\n- Precision 5 → ~5 km\n- Precision 6 → ~500 m\n\nVerdict\n\n✅ Best choice for pure location-based proximity search",
      "fontSize": 8.658019617248362,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "index": "aO",
      "boundElements": [],
      "updated": 1766904854851,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "How it works\n- Converts latitude/longitude into a string\n- Nearby locations share common prefixes\n- Precision controls search radius\n\nWhy it’s powerful\n- No tree traversal\n- Neighbor search = small string variations\n- Easy indexing in databases\n- Prebuilt libraries available\n- Scales extremely well\n\nExample\n- Precision 5 → ~5 km\n- Precision 6 → ~500 m\n\nVerdict\n\n✅ Best choice for pure location-based proximity search",
      "autoResize": true,
      "lineHeight": 1.4
    },
