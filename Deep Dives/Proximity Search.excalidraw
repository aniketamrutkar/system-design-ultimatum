      "link": null,
      "locked": false,
      "text": "SELECT * FROM restaurants\nWHERE ST_DWithin(\n  location,\n  ST_GeomFromText('POINT(0 0)'),\n  5000 -- 5km\n)",
      "fontSize": 8.578841197774738,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "EfZTbbvI4i91I3wusUbTw",
      "originalText": "SELECT * FROM restaurants\nWHERE ST_DWithin(\n  location,\n  ST_GeomFromText('POINT(0 0)'),\n  5000 -- 5km\n)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 456,
      "versionNonce": 1873644099,
      "isDeleted": false,
      "id": "nQAd038HKSbU4s2-1vg4P",
      "x": 1261.3612831507821,
