    {
      "id": "BVZhovGeK_S9So2-Xm0wi",
      "type": "text",
      "x": 3417.310481315331,
      "y": 866.0871809460499,
      "width": 190.0198516845703,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
