      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Remote Changed\n- pull for changes\n- download the new file and replace\n\n2. Local Changed\n- upload the changed files to remote\n\nWindows API\n- FileSystemWatcher\n\nMacOS API:\n- FSEvents",
      "autoResize": true,
      "lineHeight": 1.25
    },
