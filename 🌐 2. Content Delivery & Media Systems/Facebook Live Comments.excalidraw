      "text": "// In zookeeper/etcd, we maintain this state\n\n{\n    'servers':{\n        'server1':{\n            'host':'10.0.0.1',\n            'status':'healthy',\n        }\n        'videos':{\n            'video123':500,\n            'video456':300\n        }\n    },\n    'server2': {...}\n}",
