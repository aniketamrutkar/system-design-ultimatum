      "isDeleted": false,
      "boundElements": null,
      "updated": 1767479399507,
      "link": null,
      "locked": false,
      "text": "API\n\nPOST /comments/{liveVideoId} -> 200\n{\n    Comment,\n}\n\n// viewers can see all comments posted in near realtime\n\nGET /comments/{liveVideoId}?cursor={last_comment_id}&pageSize=50",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\nPOST /comments/{liveVideoId} -> 200\n{\n    Comment,\n}\n\n// viewers can see all comments posted in near realtime\n\nGET /comments/{liveVideoId}?cursor={last_comment_id}&pageSize=50",
      "autoResize": true,
      "lineHeight": 1.25
    },
