    },
    {
      "id": "zf_SWECGp6igNXdLRa-qY",
      "type": "text",
      "x": 302,
      "y": 196,
      "width": 948.9395141601562,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 304059251,
      "version": 169,
      "versionNonce": 912082643,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767476335738,
      "link": null,
      "locked": false,
      "text": "Facebook live comments is a feature that enables viewers to post comments on a live video feed.\nViewers can see a continuous stream of comments in near-real-time.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Facebook live comments is a feature that enables viewers to post comments on a live video feed.\nViewers can see a continuous stream of comments in near-real-time.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6t7crowVvB8FXTHyHzr2l",
      "type": "text",
      "x": 306,
      "y": 295,
      "width": 546.6795654296875,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1501287677,
      "version": 240,
      "versionNonce": 755739293,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767476408366,
      "link": null,
      "locked": false,
      "text": "Functional Req\n- Viewers can post comments\n- Viewers can see all comments posted in near realtime\n- viewers can see all commets posted before they joined\n\noos\n- viewers can reply to comments\n- viewers can react to comments",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Req\n- Viewers can post comments\n- Viewers can see all comments posted in near realtime\n- viewers can see all commets posted before they joined\n\noos\n- viewers can reply to comments\n- viewers can react to comments",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ZY-Qj-gA5kcGnr4PNCbUR",
      "type": "text",
      "x": 1058,
      "y": 300,
      "width": 581.8795776367188,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 719653107,
      "version": 210,
      "versionNonce": 1358439571,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767476474608,
      "link": null,
      "locked": false,
      "text": "Non Functional Req\n- Scale: millions of video w/ thousands of comments/second\n- Availability>concsistency for comment creation\n- Low latency comment broadcast (~200ms)\n\noos\n- security\n- Integrity ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non Functional Req\n- Scale: millions of video w/ thousands of comments/second\n- Availability>concsistency for comment creation\n- Low latency comment broadcast (~200ms)\n\noos\n- security\n- Integrity ",
      "autoResize": true,
      "lineHeight": 1.25
    },
