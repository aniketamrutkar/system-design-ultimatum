      "boundElements": null,
      "updated": 1767480002109,
      "link": null,
      "locked": false,
      "text": "Websockets\n- bidirectional\n- it's own protocol (not http)\n- All infra needs to support upgrading from HTTP to websockets\n- Load balancers, proxies, firewalls, all need to negotiate this upgrade",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Websockets\n- bidirectional\n- it's own protocol (not http)\n- All infra needs to support upgrading from HTTP to websockets\n- Load balancers, proxies, firewalls, all need to negotiate this upgrade",
      "autoResize": true,
      "lineHeight": 1.25
    },
