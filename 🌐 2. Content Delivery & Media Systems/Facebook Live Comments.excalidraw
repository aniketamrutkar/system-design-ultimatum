      "boundElements": null,
      "updated": 1767480004292,
      "link": null,
      "locked": false,
      "text": "SSE\n- unidirectional\n- over HTTP\n- built in browser support for reconnection\n- just looks like a long running HTTP request\n- HTTP headers to indicate we'll be sending chunks",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SSE\n- unidirectional\n- over HTTP\n- built in browser support for reconnection\n- just looks like a long running HTTP request\n- HTTP headers to indicate we'll be sending chunks",
      "autoResize": true,
      "lineHeight": 1.25
    },
