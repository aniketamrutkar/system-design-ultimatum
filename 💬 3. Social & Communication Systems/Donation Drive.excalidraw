      "link": null,
      "locked": false,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "1. Integrate with 3rd party payment provider\nlike Stripe\n2. Email on payment success\n3. View donation history\n4. Multiple charities?\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Integrate with 3rd party payment provider\nlike Stripe\n2. Email on payment success\n3. View donation history\n4. Multiple charities?\n",
      "lineHeight": 1.25,
      "index": "a4",
      "autoResize": true
    },
