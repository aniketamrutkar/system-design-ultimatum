      "link": null,
      "locked": false,
      "text": "API Designing\n- POST /api/v1/scores (views)\n- WS/GET /leaderboards/{leaderboard_id}/top?window=daily&region=IN&limit=K (1-10k) (Pagination)\n- GET /leaderboards/{leaderboard_id}/rank/{user_id}?window=month&K=5 (Pagination)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API Designing\n- POST /api/v1/scores (views)\n- WS/GET /leaderboards/{leaderboard_id}/top?window=daily&region=IN&limit=K (1-10k) (Pagination)\n- GET /leaderboards/{leaderboard_id}/rank/{user_id}?window=month&K=5 (Pagination)",
      "autoResize": true,
      "lineHeight": 1.25
    },
