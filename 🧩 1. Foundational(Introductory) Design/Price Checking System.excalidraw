    {
      "id": "BT1R4kO0gch4i3sh06TUY",
      "type": "text",
      "x": -242.19917142742452,
      "y": -780.8055260237827,
      "width": 667.9195556640625,
      "height": 1050,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
