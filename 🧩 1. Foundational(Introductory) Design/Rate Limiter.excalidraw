    {
      "id": "rolling-log-content",
      "type": "text",
      "x": -2030.9194855801238,
      "y": 1813.078852222835,
      "width": 379.3126675755403,
      "height": 79.85529843695585,
      "angle": 0,
      "strokeColor": "#7b1fa2",
      "backgroundColor": "transparent",
