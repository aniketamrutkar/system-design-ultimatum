  "elements": [
    {
      "id": "r7xW-bVel7SLI7zxZX5eS",
      "type": "text",
      "x": 1335.8451454803164,
      "y": -825.2905916389246,
      "width": 559.319580078125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
