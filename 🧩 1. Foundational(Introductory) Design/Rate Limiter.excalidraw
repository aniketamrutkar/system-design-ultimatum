    {
      "id": "CyWd4vRp_EXAQ3W4rlqbU",
      "type": "text",
      "x": 635.6827382578913,
      "y": 55.497065051453205,
      "width": 450,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
