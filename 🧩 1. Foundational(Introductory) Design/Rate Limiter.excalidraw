    {
      "id": "leaky-flow-desc",
      "type": "text",
      "x": -1641.3406717589432,
      "y": 1014.3534848812208,
      "width": 450,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f5f5f5",
      "fillStyle": "solid",
