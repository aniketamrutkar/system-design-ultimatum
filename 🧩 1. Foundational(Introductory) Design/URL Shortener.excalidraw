      "updated": 1766899016288,
      "link": null,
      "locked": false,
      "text": "Functional Req\n- Create a short url from a long url\n    - optional: support custom url\n    - optional: support expiration date\n- User should get redirected to the original url from short url",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Req\n- Create a short url from a long url\n    - optional: support custom url\n    - optional: support expiration date\n- User should get redirected to the original url from short url",
      "autoResize": true,
      "lineHeight": 1.25
    },
