      "locked": false,
      "text": "API\nPOST: /v1/url -> short-url\nJWT | session_token\n{\nlongURL,\ncustomURL?\nexpirationDate?\n}\n\nGET: /v1/url/{shortURL} -> longURL",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\nPOST: /v1/url -> short-url\nJWT | session_token\n{\nlongURL,\ncustomURL?\nexpirationDate?\n}\n\nGET: /v1/url/{shortURL} -> longURL",
