      "boundElements": [],
      "updated": 1768632089116,
      "link": null,
      "locked": false,
      "text": "NFR: \n- low latency - (TTFT) < 200 ms for streaming tokens back to chat \n- high avail - active stream highly resilent (availability>>consistency)\n- scalable - millions of conc websocket connections\n- cost management\n- no data leakage bw users\n- chat should be durable\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NFR: \n- low latency - (TTFT) < 200 ms for streaming tokens back to chat \n- high avail - active stream highly resilent (availability>>consistency)\n- scalable - millions of conc websocket connections\n- cost management\n- no data leakage bw users\n- chat should be durable\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
