    {
      "id": "Ed7LmjxkpBOD2MzyJrIFH",
      "type": "text",
      "x": -178.00353766284445,
      "y": -310.95540575164273,
      "width": 701.719482421875,
      "height": 700,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
