      "originalText": "\n\nFR: 1. receive response real time streaming\n2. conversation persistence\n3. ai must remember previous member - contextual memory\n4. ai auto naming, from initial prompt\n5. delete chats ",
      "autoResize": false,
      "lineHeight": 1.25
