      "seed": 2081365208,
      "version": 1026,
      "versionNonce": 1283649752,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768157167323,
      "link": null,
      "locked": false,
      "text": "\n\nentities: user, chat, message\n\nEntity:\nUser \nuserid(pk)\nmetadata \n\nchat: chatid(pk) , sk: chat#<timestamp>;\nmessage: chatid(pk), sk: msg#<snowflake_id>  attributes: parentid, role,\n\n --APIS:--\nList chats \nGET /v1/chats: \nspecific conversation path:\nGET /v1/chats/{chatid}/messages?branchid=abc\nDELETE /v1/chats/{chatid}\n\nws /v1/stream:\n\nclient -> server ; { chatid, prompt, parentid}\nserver -> client; { type: \"token\", data: \"hello\", messageid: \"...\" }\n\nHLD:\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\nentities: user, chat, message\n\nEntity:\nUser \nuserid(pk)\nmetadata \n\nchat: chatid(pk) , sk: chat#<timestamp>;\nmessage: chatid(pk), sk: msg#<snowflake_id>  attributes: parentid, role,\n\n --APIS:--\nList chats \nGET /v1/chats: \nspecific conversation path:\nGET /v1/chats/{chatid}/messages?branchid=abc\nDELETE /v1/chats/{chatid}\n\nws /v1/stream:\n\nclient -> server ; { chatid, prompt, parentid}\nserver -> client; { type: \"token\", data: \"hello\", messageid: \"...\" }\n\nHLD:\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
